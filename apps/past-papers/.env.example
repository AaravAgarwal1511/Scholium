VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Server configuration (for PDF composition API)
# Must match the vite proxy target in vite.config.ts. 3002, not 3000 —
# language-hub's server.js also binds 3000 and the two would race.
SERVER_PORT=3002
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Local directory holding the source PDFs + _questions.json + _mark_schemes.json
# Expected layout:
#   $PAST_PAPERS_BASE/<subject folder>/Paper 2/{questions,mark_schemes}/*.pdf
#   $PAST_PAPERS_BASE/<subject folder>/Paper 2/_questions.json
#   $PAST_PAPERS_BASE/<subject folder>/Paper 2/_mark_schemes.json
# PAST_PAPERS_BASE is the parent of the per-subject folders ("0607 (International
# Mathematics)", …); the composer resolves each subject by its leading code.
PAST_PAPERS_BASE=/Users/aarav/Desktop/Coding/Scholium/PastPapers
# Legacy single-subject fallback (base is inferred as its parent).
PAST_PAPERS_DIR=/Users/aarav/Desktop/Coding/Scholium/PastPapers/0607 (International Mathematics)

# Cloudflare R2 — the `papers` bucket.
#
# VITE_R2_PUBLIC_URL is public (it ships in the client bundle) and is the bucket's
# public r2.dev URL, or your custom domain. Setting it switches the app from the
# legacy Supabase storage bucket to R2.
#
# The rest are SECRET, server-side only. They are used to write composed chapter
# PDFs to the `_cache/` prefix (server/r2-cache.js) and by `pnpm index:papers`.
# Get them from the Cloudflare dashboard:
#   Account ID → R2 → Overview (right-hand sidebar)
#   Access key / secret → R2 → API → Manage API tokens → Create API token
#                         (needs "Object Read & Write" on the papers bucket)
#
# These must ALSO be set in the Vercel project, or POST /api/chapter-paper
# returns 500 "Missing R2 credential env var(s): …".
VITE_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=papers
